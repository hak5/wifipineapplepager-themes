{
  "screen_name": "launch_payload_dialog",
  "status_bar": "default",
  "windowed_canvas": true,
  "cache_canvases": true,
  "button_map": {
    "a": "select",
    "b": "back",
    "up": "previous",
    "down": "next",
    "left": "back",
    "right": "noop"
  },
  "background": {
    "layers": [
      {
        "image_path": "assets/launch_payload_dialog/launch_payload_bg.png",
        "x": 0,
        "y": 0
      },
      {
        "variable_name": "$_PAYLOAD_TITLE",
        "x": 30,
        "y": 68,
        "string_template": {
          "text_color_palette": "yellow",
          "text_size": "medium",
          "max_chars": 22,
          "wrap_text": false,
          "max_lines": 1
        }
      },
      {
        "text": "Author:",
        "x": 30,
        "y": 90,
        "text_size": "small",
        "text_color_palette": "medium_gray"
      },
      {
        "variable_name": "$_PAYLOAD_AUTHOR_NAME",
        "x": 95,
        "y": 90,
        "string_template": {
          "text_color_palette": "soft_white",
          "text_size": "small",
          "max_chars": 24,
          "wrap_text": false,
          "max_lines": 1
        }
      }
    ]
  },
  "menu_items": [
    {
      "id": "Launch",
      "layers": [
        {
          "image_path": "assets/payload_dialog_option_bg.png",
          "x": 28,
          "y": 117
        },
        {
          "image_path": "assets/optiondialog/check.png",
          "x": 84,
          "y": 143,
          "recolor_palette": "yellow"
        }
      ],
      "selected_layers": [
        {
          "image_path": "assets/payload_dialog_selected_box.png",
          "x": 28,
          "y": 117
        },
        {
          "image_path": "assets/optiondialog/check.png",
          "x": 84,
          "y": 143,
          "recolor_palette": "black"
        }
      ],
      "target": "launch_payload",
      "variable": "$_INPUT",
      "animation": [
        {
          "image_path": "assets/launch_payload_dialog/animation/anim_frame_1.png",
          "x": 335,
          "y": 59
        },
        {
          "image_path": "assets/launch_payload_dialog/animation/anim_frame_2.png",
          "x": 335,
          "y": 59
        },
        {
          "image_path": "assets/launch_payload_dialog/animation/anim_frame_3.png",
          "x": 335,
          "y": 59
        },
        {
          "image_path": "assets/launch_payload_dialog/animation/anim_frame_4.png",
          "x": 335,
          "y": 59
        }
      ]
    },
    {
      "id": "Cancel",
      "layers": [
        {
          "image_path": "assets/payload_dialog_option_bg.png",
          "x": 172,
          "y": 117
        },
        {
          "image_path": "assets/optiondialog/x.png",
          "x": 232,
          "y": 145,
          "recolor_palette": "disabled_dark_gray"
        }
      ],
      "selected_layers": [
        {
          "image_path": "assets/payload_dialog_option_bg.png",
          "x": 172,
          "y": 117
        },
        {
          "image_path": "assets/optiondialog/x.png",
          "x": 232,
          "y": 145,
          "recolor_palette": "white"
        }
      ],
      "target": "back"
    }
  ]
}
